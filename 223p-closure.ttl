	<http://www.w3.org/ns/shacl#construct> "\nCONSTRUCT {\n?o ?p $this .\n}\nWHERE {\n  $this ?p ?o .\n  ?p a s223:SymmetricRelation .\n}\n\t\t\t" ;
	a <http://www.w3.org/ns/shacl#SPARQLRule> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "Declare the inverse triples for symmetric relations" .
