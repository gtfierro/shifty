	<http://www.w3.org/ns/shacl#construct> "\nCONSTRUCT {$this s223:connectedTo ?equipment .}\nWHERE {\n$this s223:hasConnectionPoint ?cp .\n?cp a s223:OutletConnectionPoint .\n?cp s223:connectsThrough/s223:connectsTo ?equipment .\n}\n" ;
	a <http://www.w3.org/ns/shacl#SPARQLRule> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "Infer the `connectedTo` relation using `connectsThrough` and `connectsTo`." .
