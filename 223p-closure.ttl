	<http://www.w3.org/ns/shacl#construct> "\nCONSTRUCT {?y s223:hasAspect  s223:Aspect-Setpoint}\nWHERE {\n?prop s223:hasSetpoint ?y .\nFILTER NOT EXISTS {?y s223:hasAspect s223:Aspect-Setpoint}\n}\n" ;
	a <http://www.w3.org/ns/shacl#SPARQLRule> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "Infer the `hasAspect s223:Aspect-Setpoint` for properties referred to by `hasSetpoint`" .
