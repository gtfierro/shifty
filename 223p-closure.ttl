_:e5836db1a7f722f7ed4db1aac4cec749 <http://www.w3.org/ns/shacl#select> "\nSELECT $this ?cp ?con\nWHERE {\n$this s223:hasBoundaryConnectionPoint ?cp .\n?cp s223:isConnectionPointOf ?con .\nFILTER NOT EXISTS {$this s223:hasMember+ ?con}\n}\n" ;
