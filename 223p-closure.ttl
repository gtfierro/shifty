_:d3ebfc85303d87e7a62723fbb8b242b5 <http://www.w3.org/ns/shacl#select> "\nSELECT ?this ?m2 ?m1\nWHERE {\n  ?this s223:cnx ?cp1, ?cp2 .\n  ?cp1 a/rdfs:subClassOf* s223:ConnectionPoint .\n  ?cp2 a/rdfs:subClassOf* s223:ConnectionPoint .\n  FILTER (?cp1 != ?cp2) .\n  ?cp1 s223:hasMedium ?m1 .\n  ?cp2 s223:hasMedium ?m2 .\n    ?m1 s223:composedOf/s223:ofConstituent ?s1 .\n    ?m2 s223:composedOf/s223:ofConstituent ?s2 .\n  FILTER NOT EXISTS {\n    ?m1 s223:composedOf/s223:ofConstituent ?s11 .\n    ?m2 s223:composedOf/s223:ofConstituent ?s12 .\n    FILTER (?s11 = ?s12) .\n  }\n  FILTER NOT EXISTS {\n    ?m1 s223:composedOf/s223:ofConstituent ?s21 .\n    ?m2 s223:composedOf/s223:ofConstituent ?s22 .\n    {?s22 rdfs:subClassOf* ?s21} UNION {?s21 rdfs:subClassOf* ?s22} .\n  }\n}\n" ;
	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "Incompatible Medium. Case 3: Two mediums with constituents." ;
	<http://www.w3.org/ns/shacl#message> "s223: For `Filter` {$this} there is no compatible substance between medium {?m2} and medium {?m1}." .
_:d4263aa5fabd8e66207e75a7ff260a57 <http://www.w3.org/ns/shacl#select> "\nSELECT $this\nWHERE {\n$this s223:hasInternalReference ?int .\n$this s223:hasExternalReference ?ext .\n}\n" ;
	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "A `Property` must not have both a `hasInternalReference` and a `hasExternalReference` relation." ;
	<http://www.w3.org/ns/shacl#message> "s223: {$this} cannot have both a `hasInternalReference` and a `hasExternalReference` relation." .
