	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	<http://www.w3.org/ns/shacl#construct> "\nCONSTRUCT {$this s223:connected ?d2 .}\nWHERE {\n$this s223:connectedThrough/^s223:connectedThrough ?d2 .\nFILTER ($this != ?d2) .\nFILTER NOT EXISTS {$this s223:contains* ?d2} .\nFILTER NOT EXISTS {?d2 s223:contains* $this} .\n}\n" ;
	a <http://www.w3.org/ns/shacl#SPARQLRule> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "Infer the `connected` relation for BiDirectional connections" .
_:d8ec32b271daca9ee66235f6b07e75b0 <http://www.w3.org/ns/shacl#select> "\nSELECT $this ?v ?subject\nWHERE {\n$this s223:hasValue ?v .\nFILTER NOT EXISTS {$this qudt:hasUnit ?u} .\n?subject ?p $this .\n}\n" ;
	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "This `QuantifiableProperty` cannot have a value without a `Unit`." ;
	<http://www.w3.org/ns/shacl#message> "s223: {$this} referenced by {?subject} has a value of {?v} but does not specify a `Unit`." .
