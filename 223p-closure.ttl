_:e3db780b777a1426c3104a36883114e6 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this ?c\n            WHERE {\n              $this a ?c .\n              ?c   a s223:AbstractClass .\n              FILTER NOT EXISTS {\n                $this a ?nonAbs .\n                ?nonAbs rdfs:subClassOf+ ?c .\n                FILTER NOT EXISTS { ?nonAbs a s223:AbstractClass }\n              }\n            }\n        " ;
	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
	<http://www.w3.org/ns/shacl#message> "s223: {$this} cannot be declared an instance of only {?c}, which is an abstract class." .
