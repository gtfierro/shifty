_:d482b42e8dc0e96771c0edce9a0a52ea a sh:SPARQLConstraint ;
    sh:message "{$this} has type {?class} which was deprecated in version {?depver}. For now, it has been updated to also be of type {?newClass}."^^xsd:string ;
    sh:prefixes <https://brickschema.org/schema/1.4/Brick> ;
    sh:select """SELECT $this ?class ?newClass ?depver WHERE {
$this a ?class .
?class owl:deprecated true .
?class brick:deprecatedInVersion ?depver .
?class brick:isReplacedBy ?newClass .
}"""^^xsd:string .

