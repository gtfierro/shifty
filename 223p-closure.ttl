_:b98b24f37a5c3c6072e2b60a19258611 <http://www.w3.org/ns/shacl#select> "\n    SELECT $this ?myphase ?cp ?cpPhase\n    WHERE {\n        $this s223:hasElectricalPhase ?myphase .\n        $this s223:connectsAt ?cp .\n        ?cp s223:hasElectricalPhase ?cpPhase .\n        FILTER (?myphase != ?cpPhase) .\n        }\n        " ;
	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "Ensure the electrical phase is the same as all connected `ConnectionPoint`s" ;
	<http://www.w3.org/ns/shacl#message> "s223: {$this} has an electrical phase of {?myphase} which is different from {?cpPhase} for `ConnectionPoint` {?cp}." .
