	<http://qudt.org/schema/qudt/hasQuantityKind> <http://qudt.org/vocab/quantitykind/Voltage> ;
	a <http://data.ashrae.org/standard223#Class> , <http://data.ashrae.org/standard223#Voltage-230V> , <http://www.w3.org/ns/shacl#NodeShape> ;
