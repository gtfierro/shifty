_:cb08a56d657dc04d03aa0f2a287caa4f <http://www.w3.org/ns/shacl#select> "\nSELECT $this\nWHERE {\n  FILTER NOT EXISTS {\n    $this s223:contains ?voltageSensor .\n    $this s223:contains ?currentSensor .\n    ?voltageSensor a/rdfs:subClassOf* s223:VoltageSensor ;\n                   s223:hasObservationLocation ?location .\n    ?currentSensor a/rdfs:subClassOf* s223:ElectricCurrentSensor ;\n                   s223:hasObservationLocation ?location .\n  }\n}\n" ;
	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "An `ElectricityMeter` shall contain a `VoltageSensor` and `ElectricCurrentSensor` with the same observation location." ;
	<http://www.w3.org/ns/shacl#message> "s223: {$this} does not contain a `VoltageSensor` and `ElectricCurrentSensor` with a shared observation location." .
