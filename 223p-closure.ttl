_:ff2a170de6820a13bfd7438251e51a5a <http://www.w3.org/ns/shacl#select> "\nSELECT $this ?equipment ?otherEquipment\nWHERE {\n$this s223:mapsTo ?otherCP .\n?equipment s223:hasConnectionPoint $this .\n?otherEquipment s223:hasConnectionPoint ?otherCP .\nFILTER NOT EXISTS {?otherEquipment s223:contains ?equipment}\n}\n" ;
	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "If a `ConnectionPoint` `mapsTo` another `ConnectionPoint`, the respective `Equipment` should have a `contains` relation." ;
	<http://www.w3.org/ns/shacl#message> "s223: {?otherEquipment} should contain {?equipment} because `ConnectionPoint` {$this} has a `mapsTo` relation." .
