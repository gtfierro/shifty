_:cc9d00a4e51cb87908e8dc54d7c5773b <http://www.w3.org/ns/shacl#select> "\n    SELECT $this ?containerEquipment\n    WHERE {\n        FILTER NOT EXISTS {$this s223:connectsThrough ?anything1} .\n        FILTER NOT EXISTS {$this s223:mapsTo ?anything2} .\n        FILTER NOT EXISTS {?anything3 s223:hasBoundaryConnectionPoint $this} .\n        $this s223:isConnectionPointOf ?equipment .\n        ?containerEquipment s223:contains ?equipment .\n        }\n        " ;
	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "If a `ConnectionPoint` lacks a `connectsThrough` and `mapsTo` relation, but is associated with a `Junction` or `Equipment` that is contained by an `Equipment`, then suggest that the `ConnectionPoint` might need a `mapsTo` relation to a `ConnectionPoint` of the containing `Equipment`." ;
	<http://www.w3.org/ns/shacl#message> "s223: `ConnectionPoint` {$this} could be missing a `mapsTo` relation to a `ConnectionPoint` of {?containerEquipment} because it is associated with a `Junction` or `Equipment` that is contained by {?containerEquipment}." .
