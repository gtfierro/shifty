@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

[] a sh:ValidationReport ;
    sh:conforms false ;
    sh:result [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/HPL#PressureSensor_8> ;
            sh:resultMessage "s223: A `Sensor` shall be associated with exactly 1 of `Connectable`, `Connection`, or `ConnectionPoint` using the relation `hasObservationLocation`." ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:XoneConstraintComponent ;
            sh:sourceShape <http://data.ashrae.org/standard223#SensorObservationLocationShape> ;
            sh:value <http://example.org/HPL#PressureSensor_8> ],
        [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/HPL#TemperatureSensor_15> ;
            sh:resultMessage "s223: A `Sensor` shall be associated with exactly 1 of `Connectable`, `Connection`, or `ConnectionPoint` using the relation `hasObservationLocation`." ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:XoneConstraintComponent ;
            sh:sourceShape <http://data.ashrae.org/standard223#SensorObservationLocationShape> ;
            sh:value <http://example.org/HPL#TemperatureSensor_15> ],
        [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/HPL#TemperatureSensor_30> ;
            sh:resultMessage "s223: A `Sensor` shall be associated with exactly 1 of `Connectable`, `Connection`, or `ConnectionPoint` using the relation `hasObservationLocation`." ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:XoneConstraintComponent ;
            sh:sourceShape <http://data.ashrae.org/standard223#SensorObservationLocationShape> ;
            sh:value <http://example.org/HPL#TemperatureSensor_30> ] .

