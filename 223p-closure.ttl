_:cc2f50c88b106f8701c62ab9201f7d4c <http://www.w3.org/ns/shacl#select> "\nSELECT $this ?cp1 ?m1 ?cp2 ?m2\nWHERE {\n$this s223:cnx ?cp1 .\n?cp1 a/rdfs:subClassOf* s223:ConnectionPoint .\n?cp1 s223:hasMedium ?m1 .\n$this s223:cnx ?cp2 .\n?cp2 a/rdfs:subClassOf* s223:ConnectionPoint .\nFILTER (?cp1 != ?cp2 ) .\n?cp2 s223:hasMedium ?m2 .\nFILTER (?m1 != ?m2 ) .\nFILTER NOT EXISTS {?m1 s223:composedOf ?c1} .\nFILTER NOT EXISTS {?m2 s223:composedOf ?c2}\nFILTER (NOT EXISTS {?m2 rdfs:subClassOf* ?m1}) .\nFILTER (NOT EXISTS {?m1 rdfs:subClassOf* ?m2}) .\n}\n" ;
	<http://www.w3.org/ns/shacl#prefixes> <http://data.ashrae.org/standard223/1.0/model/all> ;
	a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "Incompatible Medium. Case 5: Two `ConnectionPoint`s with pure mediums." ;
	<http://www.w3.org/ns/shacl#message> "s223: {?cp1} with Medium {?m1} is incompatible with {?cp2} with Medium {?m2}." .
